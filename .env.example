# =============================================================================
# ShareDrop — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All variables have sensible defaults — the app runs out of the box.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_PASSWORD=sharedrop_secret

# --- JWT ----------------------------------------------------------------------
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRY=24h

# --- Email domain whitelist ---------------------------------------------------
# Comma-separated list of allowed email domains. Empty = allow all.
ALLOWED_EMAIL_DOMAINS=example.com,example.org

# --- OTP ----------------------------------------------------------------------
OTP_EXPIRY_MINUTES=10

# --- Shares -------------------------------------------------------------------
# SHARE_EXPIRY_OPTIONS_DAYS: options shown in UI (comma-separated)
SHARE_EXPIRY_OPTIONS_DAYS=1,3,5,7,14
SHARE_DEFAULT_EXPIRY_DAYS=3
REPLY_SHARE_EXPIRY_DAYS=7

# --- File limits --------------------------------------------------------------
# MAX_FILE_SIZE_MB: max per file (e.g. 51200 = 50 GB)
MAX_FILE_SIZE_MB=51200
CHUNK_SIZE_MB=5

# --- Email mode (smtp / oauth2 use SMTP_FROM) ---------------------------------
# "none"   — OTP codes logged to console only (development/testing)
# "smtp"   — Classic SMTP with username/password
# "oauth2" — Exchange Online with OAuth2 (see docs/EXCHANGE_OAUTH2_SETUP.md)
SMTP_MODE=none
SMTP_FROM=noreply@sharedrop.local

# --- SMTP (classic) — used when SMTP_MODE=smtp --------------------------------
# SMTP_TLS_REJECT_UNAUTHORIZED=false — use when connecting via IP (e.g. 10.0.0.1) to server with DNS cert
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password

# --- Exchange Online OAuth2 — used when SMTP_MODE=oauth2 ----------------------
# See docs/EXCHANGE_OAUTH2_SETUP.md for setup instructions
SMTP_OAUTH2_TENANT_ID=
SMTP_OAUTH2_CLIENT_ID=
SMTP_OAUTH2_CLIENT_SECRET=

# --- Branding -----------------------------------------------------------------
# APP_NAME: shown in emails and notifications (default: ShareDrop)
APP_NAME=ShareDrop
# VITE_COMPANY_LOGO_URL: logo in header (relative to public/, or absolute URL)
VITE_COMPANY_LOGO_URL=
# VITE_COMPANY_NAME: company name shown next to logo (default: ShareDrop)
VITE_COMPANY_NAME=ShareDrop

# --- Admin console ------------------------------------------------------------
# Comma-separated list of admin emails with roles.
# Format: email:role (role = admin | viewer)
# "admin" — full access (read, delete shares)
# "viewer" — read-only access (monitoring, statistics)
ADMIN_EMAILS=admin@example.com:admin,viewer@example.com:viewer
ADMIN_PORT=8084

# --- Disk monitoring ----------------------------------------------------------
# DISK_WARN_THRESHOLD_PERCENT: warn admins when free space drops below (default 15)
# DISK_BLOCK_THRESHOLD_PERCENT: block uploads when free space drops below (default 5)
# ADMIN_NOTIFY_DEBOUNCE_MINUTES: min interval between same notification type (default 60)
DISK_WARN_THRESHOLD_PERCENT=15
DISK_BLOCK_THRESHOLD_PERCENT=5
ADMIN_NOTIFY_DEBOUNCE_MINUTES=60

# --- SSL mode -----------------------------------------------------------------
# "external" — SSL terminated by reverse proxy (default, container serves HTTP)
# "docker"   — SSL in container (requires certificates in ./certs/)
SSL_MODE=external

# --- SSL certificates — only for SSL_MODE=docker ------------------------------
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# --- Ports --------------------------------------------------------------------
APP_PORT=8080
APP_SSL_PORT=8443
